@model SV_22T1020607.Models.Catalog.Product
@{
    ViewData["Title"] = Model.ProductName;
    var photos = (ViewBag.Photos as IEnumerable<SV_22T1020607.Models.Catalog.ProductPhoto>)
                 ?.Where(p => !p.IsHidden).ToList();
    var attributes = ViewBag.Attributes as IEnumerable<SV_22T1020607.Models.Catalog.ProductAttribute>;
    string mainPhoto = string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo;
    string categoryName = ViewBag.CategoryName ?? "";
    string supplierName = ViewBag.SupplierName ?? "";
}

<style>
    .product-detail-img {
        width: 100%;
        max-height: 420px;
        object-fit: contain;
        border-radius: 12px;
        background: #f8f9fa;
        padding: 12px;
        border: 1px solid #e9ecef;
        transition: transform 0.3s ease;
    }
    .thumb-img {
        width: 80px;
        height: 80px;
        object-fit: contain;
        background: #f8f9fa;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.2s;
        padding: 4px;
    }
    .thumb-img:hover, .thumb-img.active {
        border-color: #0d6efd;
        transform: scale(1.05);
    }
    .price-badge {
        background: linear-gradient(135deg, #e63946, #c1121f);
        color: white;
        border-radius: 10px;
        padding: 10px 20px;
        display: inline-block;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .attr-table th {
        background-color: #f1f3f5;
        font-weight: 600;
        width: 35%;
    }
    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #212529;
        border-left: 4px solid #0d6efd;
        padding-left: 10px;
        margin-bottom: 16px;
    }
    .badge-selling {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #6ee7b7;
        font-size: 0.8rem;
        padding: 4px 10px;
        border-radius: 20px;
    }
    .qty-input {
        width: 80px;
        text-align: center;
        border-radius: 8px;
        border: 1px solid #ced4da;
        font-size: 1rem;
        padding: 8px;
    }
</style>

<div class="container mt-4">
    @* Breadcrumb *@
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row mb-5 bg-white p-4 rounded-3 shadow-sm">

        @* ===== CỘT TRÁI: ẢNH ===== *@
        <div class="col-md-5 mb-4 mb-md-0">
            @* Ảnh chính *@
            <img id="mainProductImg"
                 src="http://localhost:5030/images/products/@mainPhoto"
                 onerror="this.src='http://localhost:5030/images/products/nophoto.png';"
                 class="product-detail-img mb-3"
                 alt="@Model.ProductName" />

            @* Ảnh phụ (thumbnail) *@
            @if (photos != null && photos.Any())
            {
                <div class="d-flex flex-wrap gap-2 mt-2">
                    @* Thumbnail ảnh chính *@
                    <img src="http://localhost:5030/images/products/@mainPhoto"
                         onerror="this.src='http://localhost:5030/images/products/nophoto.png';"
                         class="thumb-img active"
                         onclick="switchImage(this, 'http://localhost:5030/images/products/@mainPhoto')"
                         title="Ảnh chính" />

                    @* Thumbnail ảnh bổ sung *@
                    @foreach (var p in photos)
                    {
                        <img src="http://localhost:5030/images/products/@p.Photo"
                             onerror="this.style.display='none';"
                             class="thumb-img"
                             onclick="switchImage(this, 'http://localhost:5030/images/products/@p.Photo')"
                             title="@p.Description" />
                    }
                </div>
            }
        </div>

        @* ===== CỘT PHẢI: THÔNG TIN ===== *@
        <div class="col-md-7">
            @* Tên sản phẩm *@
            <h1 class="fs-3 fw-bold mb-2">@Model.ProductName</h1>

            @* Trạng thái *@
            @if (Model.IsSelling)
            {
                <span class="badge-selling mb-3 d-inline-block">
                    ✅ Còn hàng
                </span>
            }
            else
            {
                <span class="badge bg-secondary mb-3 d-inline-block">Ngừng bán</span>
            }

            @* Giá *@
            <div class="my-3">
                <span class="price-badge">@Model.Price.ToString("N0") ₫</span>
            </div>

            @* Thông tin cơ bản *@
            <table class="table table-sm table-borderless mb-3" style="max-width: 480px;">
                <tbody>
                    @if (!string.IsNullOrWhiteSpace(Model.Unit))
                    {
                        <tr>
                            <td class="text-muted fw-semibold" style="width:140px;">Đơn vị tính</td>
                            <td><strong>@Model.Unit</strong></td>
                        </tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(categoryName))
                    {
                        <tr>
                            <td class="text-muted fw-semibold">Loại hàng</td>
                            <td>@categoryName</td>
                        </tr>
                    }
                    @if (!string.IsNullOrWhiteSpace(supplierName))
                    {
                        <tr>
                            <td class="text-muted fw-semibold">Nhà cung cấp</td>
                            <td>@supplierName</td>
                        </tr>
                    }
                    <tr>
                        <td class="text-muted fw-semibold">Giá bán</td>
                        <td><strong class="text-danger">@Model.Price.ToString("N0") ₫</strong></td>
                    </tr>
                </tbody>
            </table>

            @* Mô tả *@
            @if (!string.IsNullOrWhiteSpace(Model.ProductDescription))
            {
                <div class="mb-4">
                    <div class="section-title">Mô tả sản phẩm</div>
                    <p class="text-secondary" style="line-height: 1.7;">@Model.ProductDescription</p>
                </div>
            }

            <hr />

            @* Nút Thêm vào giỏ *@
            <div class="d-flex align-items-center gap-3 my-4">
                <input type="number" id="qty" class="qty-input" value="1" min="1" max="999" />
                <a asp-controller="Cart" asp-action="Add" asp-route-id="@Model.ProductID"
                   class="btn btn-primary btn-lg flex-grow-1 fw-bold rounded-3">
                    <i class="fa-solid fa-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG
                </a>
            </div>

            @* Thuộc tính kỹ thuật *@
            @if (attributes != null && attributes.Any())
            {
                <div class="mt-4">
                    <div class="section-title">Thông số kỹ thuật</div>
                    <table class="table table-striped table-bordered attr-table">
                        <tbody>
                            @foreach (var attr in attributes.OrderBy(a => a.DisplayOrder))
                            {
                                <tr>
                                    <th>@attr.AttributeName</th>
                                    <td>@attr.AttributeValue</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    function switchImage(thumb, src) {
        document.getElementById('mainProductImg').src = src;
        document.querySelectorAll('.thumb-img').forEach(t => t.classList.remove('active'));
        thumb.classList.add('active');
    }
</script>
}

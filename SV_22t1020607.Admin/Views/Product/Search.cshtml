@model SV_22T1020607.Models.Common.PagedResult<SV_22T1020607.Models.Catalog.Product>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng. 
    Trang <strong>@Model.Page</strong> trên tổng số <strong>@Model.PageCount</strong> trang.
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width: 80px">Ảnh</th>
                    <th>Tên mặt hàng</th>
                    <th>Đơn vị tính</th>
                    <th>Giá</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/nophoto.png" : $"/images/products/{item.Photo}")" alt="@item.ProductName" class="img-thumbnail" style="width: 60px" />
                        </td>
                        <td>
                            <strong>@item.ProductName</strong>
                            <div class="small text-muted">@item.ProductDescription</div>
                        </td>
                        <td>@item.Unit</td>
                        <td>@item.Price.ToString("N0")</td>
                        <td class="text-center text-nowrap">
                            <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary me-1" title="Cập nhật">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("_Pager", Model)
</div>

@model SV_22T1020607.Models.Common.PagedResult<SV_22T1020607.Models.HR.Employee>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên.
    Trang <strong>@Model.Page</strong> trên tổng số <strong>@Model.PageCount</strong> trang.
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td class="text-center">
                            @if (item.IsWorking == true)
                            {
                                <span class="badge bg-success">Đang làm việc</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã nghỉ việc</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary" title="Cập nhật">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning ms-2" title="Đổi mật khẩu">
                                <i class="bi bi-key"></i>
                            </a>
                            <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info" title="Cấp quyền">
                                <i class="bi bi-shield-check"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("_Pager", Model)
</div>

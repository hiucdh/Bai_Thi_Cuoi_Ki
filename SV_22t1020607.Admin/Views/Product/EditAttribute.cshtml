@model SV_22T1020607.Models.Catalog.ProductAttribute
@{
    int productId = ViewBag.ProductID ?? Model.ProductID;
}
@section PageToolBar {
    <button type="submit" form="formEditAttribute" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu thuộc tính
    </button>
    <a href="~/Product/Edit/@productId" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>
            <div class="card-body">
                <form id="formEditAttribute" action="~/Product/SaveAttribute" method="post">
                    <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
                    <input type="hidden" name="ProductID" value="@productId" />

                    @* Tên thuộc tính *@
                    @{
                        bool nameErr = ViewData.ModelState.ContainsKey(nameof(Model.AttributeName))
                                      && ViewData.ModelState[nameof(Model.AttributeName)]!.Errors.Count > 0;
                    }
                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Tên thuộc tính <span class="text-danger">*</span>
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeName"
                                   value="@Model.AttributeName"
                                   class="form-control @(nameErr ? "is-invalid" : "")"
                                   placeholder="Ví dụ: Màu sắc, Kích thước, Chất liệu"
                                   autofocus />
                            @if (nameErr)
                            {
                                <div class="invalid-feedback">
                                    <i class="bi bi-exclamation-circle"></i>
                                    @ViewData.ModelState[nameof(Model.AttributeName)]!.Errors[0].ErrorMessage
                                </div>
                            }
                        </div>
                    </div>

                    @* Giá trị thuộc tính *@
                    @{
                        bool valueErr = ViewData.ModelState.ContainsKey(nameof(Model.AttributeValue))
                                        && ViewData.ModelState[nameof(Model.AttributeValue)]!.Errors.Count > 0;
                    }
                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Giá trị <span class="text-danger">*</span>
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeValue"
                                   value="@Model.AttributeValue"
                                   class="form-control @(valueErr ? "is-invalid" : "")"
                                   placeholder="Ví dụ: Đỏ, XL, 500g" />
                            @if (valueErr)
                            {
                                <div class="invalid-feedback">
                                    <i class="bi bi-exclamation-circle"></i>
                                    @ViewData.ModelState[nameof(Model.AttributeValue)]!.Errors[0].ErrorMessage
                                </div>
                            }
                        </div>
                    </div>

                    @* Thứ tự hiển thị *@
                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="@(Model.DisplayOrder == 0 ? 1 : Model.DisplayOrder)"
                                   min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

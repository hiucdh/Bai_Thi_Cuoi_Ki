@model SV_22T1020607.Models.Common.PaginationSearchResult<SV_22T1020607.Models.Partner.Supplier>
@{
    ViewBag.Title = "Quản lý Nhà cung cấp";
}
@section PageToolBar {
    <a href="~/Supplier/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Supplier/Index" method="get">
            <div class="input-group">
                <input type="text"
                       name="searchValue"
                       class="form-control"
                       value="@Model.SearchValue"
                       placeholder="Tên nhà cung cấp..." autofocus />
                <button class="btn btn-info d-flex align-items-center" type="submit">
                    <i class="bi bi-search me-1"></i>
                    Tìm kiếm
                </button>
            </div>
            <input type="hidden" name="page" value="@Model.Page" id="hiddenPageNo" />
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhà cung cấp. 
    Trang <strong>@Model.Page</strong> trên tổng số <strong>@Model.PageCount</strong> trang.
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên nhà cung cấp</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Data)
                {
                    <tr>
                        <td>@item.SupplierName</td>
                        <td>@item.ContactName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td>@item.Province</td>
                        <td class="text-center">
                            <a href="~/Supplier/Edit/@item.SupplierID" class="btn btn-sm btn-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Supplier/Delete/@item.SupplierID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        @if (Model.PageCount > 1)
        {
            <!-- Pagination -->
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page - 1))">&laquo;</a>
                </li>
                @{
                    int p = 1, pEnd = Model.PageCount;
                    if (Model.PageCount > 7) {
                        p = Math.Max(1, Model.Page - 3);
                        pEnd = Math.Min(Model.PageCount, Model.Page + 3);
                        if (p == 1) pEnd = 7;
                        if (pEnd == Model.PageCount) p = Model.PageCount - 6;
                    }
                }
                @for (int i = p; i <= pEnd; i++)
                {
                    if (i == Model.Page)
                    {
                        <li class="page-item active"><a class="page-link" href="#">@i</a></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" href="javascript:;" onclick="doSearch(@i)">@i</a></li>
                    }
                }
                <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page + 1))">&raquo;</a>
                </li>
            </ul>
        }
    </div>
</div>

@section Scripts {
    <script>
        function doSearch(page) {
            document.getElementById('hiddenPageNo').value = page;
            document.getElementById('formSearch').submit();
        }
    </script>
}

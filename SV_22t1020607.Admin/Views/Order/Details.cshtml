@model SV_22T1020607.Models.Sales.OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {
    <div class="btn-group">
        <button type="button"
                class="btn btn-primary dropdown-toggle"
                data-bs-toggle="dropdown">
            <i class="bi bi-gear me-1"></i>
            Xử lý đơn hàng
        </button>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
            <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
            <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
            <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a></li>
        </ul>
    </div>

    <a href="~/Order/Delete/@Model.OrderID"
       class="btn btn-danger ms-1 open-modal">
        <i class="bi bi-trash"></i>
        Xóa
    </a>

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<!-- TRẠNG THÁI ĐƠN HÀNG -->
@{
    var statusClass = "alert-secondary";
    var statusText = "";
    var statusIcon = "bi-info-circle";
    if (Model.Status == SV_22T1020607.Models.Sales.OrderStatusEnum.New)
    {
        statusClass = "alert-primary";
        statusText = "Đơn hàng mới: Đang chờ duyệt";
        statusIcon = "bi-bell";
    }
    else if (Model.Status == SV_22T1020607.Models.Sales.OrderStatusEnum.Accepted)
    {
        statusClass = "alert-info";
        statusText = $"Đã duyệt lúc {Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm")}";
        statusIcon = "bi-check2-circle";
    }
    else if (Model.Status == SV_22T1020607.Models.Sales.OrderStatusEnum.Shipping)
    {
        statusClass = "alert-warning";
        statusText = $"Đang giao hàng, bắt đầu lúc {Model.ShippedTime?.ToString("dd/MM/yyyy HH:mm")}";
        statusIcon = "bi-truck";
    }
    else if (Model.Status == SV_22T1020607.Models.Sales.OrderStatusEnum.Completed)
    {
        statusClass = "alert-success";
        statusText = $"Đã hoàn tất lúc {Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")}";
        statusIcon = "bi-check-circle-fill";
    }
    else if (Model.Status == SV_22T1020607.Models.Sales.OrderStatusEnum.Cancelled)
    {
        statusClass = "alert-danger";
        statusText = $"Bị hủy lúc {Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")}";
        statusIcon = "bi-x-circle";
    }
    else if (Model.Status == SV_22T1020607.Models.Sales.OrderStatusEnum.Rejected)
    {
        statusClass = "alert-dark";
        statusText = $"Bị từ chối lúc {Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")}";
        statusIcon = "bi-slash-circle";
    }
}
<div class="alert @statusClass d-flex align-items-center mb-3">
    <i class="bi @statusIcon fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @statusText
    </div>
</div>

<!-- THÔNG TIN ĐƠN HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>

            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@Model.EmployeeName</div>

            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa nhận")</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN KHÁCH HÀNG -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>

            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.CustomerEmail</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN GIAO HÀNG -->
<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>
            Thông tin giao hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@Model.ShipperName</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                    decimal total = 0;
                    var details = ViewBag.Details as IEnumerable<SV_22T1020607.Models.Sales.OrderDetailViewInfo>;
                }
                @if (details != null)
                {
                    foreach (var item in details)
                    {
                        decimal amount = item.Quantity * item.SalePrice;
                        total += amount;
                        <tr>
                            <td class="text-center">@i</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@amount.ToString("N0")</td>
                            <td class="text-end">
                                <a href="~/Order/EditCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-primary open-modal">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Order/DeleteCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-danger open-modal">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@total.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}
@model IEnumerable<SV22T1020607.Shop.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="row mt-4">
    <div class="col-md-7">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fa-solid fa-map-location-dot me-2"></i>Thông tin nhận hàng</h5>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationMessage("Error")
                    </div>
                }

                <form asp-action="Init" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tỉnh / Thành</label>
                        <select class="form-select" name="deliveryProvince" required>
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            @if(ViewBag.Provinces != null)
                            {
                                foreach(var p in ViewBag.Provinces)
                                {
                                    <option value="@p.ProvinceName">@p.ProvinceName</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">Địa chỉ chi tiết (Số nhà, Đường)</label>
                        <input type="text" class="form-control" name="deliveryAddress" required placeholder="Nhập địa chỉ nhận hàng...">
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại Giỏ hàng
                        </a>
                        <button type="submit" class="btn btn-success fw-bold px-5">
                            <i class="fa-solid fa-check me-1"></i> Xác nhận Đặt Hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="fa-solid fa-box me-2"></i>Đơn hàng của bạn (@Model.Count() sản phẩm)</h5>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var item in Model)
                {
                    <li class="list-group-item d-flex justify-content-between lh-sm py-3">
                        <div>
                            <h6 class="my-0">@item.ProductName</h6>
                            <small class="text-muted">Số lượng: @item.Quantity x @item.SalePrice.ToString("N0")</small>
                        </div>
                        <span class="text-danger fw-bold">@item.TotalPrice.ToString("N0")</span>
                    </li>
                }
                <li class="list-group-item d-flex justify-content-between bg-light py-3">
                    <div class="text-success">
                        <h6 class="my-0 fw-bold">Tổng cộng (VNĐ)</h6>
                    </div>
                    <span class="text-success fw-bold fs-5">@Model.Sum(m => m.TotalPrice).ToString("N0")</span>
                </li>
            </ul>
        </div>
    </div>
</div>

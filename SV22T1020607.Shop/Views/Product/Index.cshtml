@model IEnumerable<SV_22T1020607.Models.Catalog.Product>
@{
    ViewData["Title"] = "Cửa hàng Kỹ Thuật Số";
}

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fa-solid fa-filter me-2"></i>Bộ lọc</h5>
            </div>
            <div class="card-body">
                <form id="frmSearch" asp-action="Index" method="get">
                    <input type="hidden" name="page" value="1" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Từ khóa</label>
                        <input type="text" class="form-control" name="searchValue" value="@ViewBag.SearchValue" placeholder="Tên sản phẩm...">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Danh mục</label>
                        <select class="form-select" name="categoryID">
                            <option value="0">-- Tất cả danh mục --</option>
                            @foreach (var item in SV22T1020607.BusinessLayers.CommonDataService.ListOfCategories())
                            {
                                if (item.CategoryID == ViewBag.CategoryID)
                                {
                                    <option value="@item.CategoryID" selected>@item.CategoryName</option>
                                }
                                else
                                {
                                    <option value="@item.CategoryID">@item.CategoryName</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mức giá</label>
                        <input type="number" class="form-control mb-2" name="minPrice" placeholder="Giá từ..." value="@(ViewBag.MinPrice > 0 ? ViewBag.MinPrice : "")" />
                        <input type="number" class="form-control" name="maxPrice" placeholder="Đến giá..." value="@(ViewBag.MaxPrice > 0 ? ViewBag.MaxPrice : "")" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-magnifying-glass me-2"></i>Tìm kiếm</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Xóa bộ lọc</a>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold text-dark">Danh sách Sản phẩm</h4>
            <span class="text-muted">Tìm thấy <b>@ViewBag.RowCount</b> kết quả</span>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            @if(Model != null)
            {
                foreach(var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 product-card">
                            <img src="http://localhost:5030/images/products/@(string.IsNullOrEmpty(item.Photo) ? "macbook.png" : item.Photo)" 
                                onerror="this.src='/images/no-image.png';" 
                                class="card-img-top p-3" alt="@item.ProductName" style="height: 220px; object-fit: contain;">
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title text-truncate fw-bold" title="@item.ProductName">@item.ProductName</h6>
                                <p class="card-text text-danger fw-bold fs-5 mb-3">@item.Price.ToString("N0") đ</p>
                                <div class="mt-auto row g-2">
                                    <div class="col-6">
                                        <a asp-action="Details" asp-route-id="@item.ProductID" class="btn btn-outline-primary w-100"><i class="fa-solid fa-eye"></i> Xem</a>
                                    </div>
                                    <div class="col-6">
                                        <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.ProductID" class="btn btn-primary w-100"><i class="fa-solid fa-cart-shopping"></i> Mua</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Phân trang -->
        @if (ViewBag.PageCount > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    @{
                        var pagerModel = new SV_22T1020607.Models.Common.PagedResult<object>
                        {
                            Page = ViewBag.Page,
                            PageSize = 12,
                            RowCount = ViewBag.RowCount
                        };
                    }
                    @foreach (var pageItem in pagerModel.GetDisplayPages(4))
                    {
                        if (pageItem.Page == 0)
                        {
                            <li class="page-item disabled"><a class="page-link" href="#">...</a></li>
                        }
                        else if (pageItem.IsCurrent)
                        {
                            <li class="page-item active"><a class="page-link" href="#">@pageItem.Page</a></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="javascript:;" onclick="doSearch(@pageItem.Page)">@pageItem.Page</a></li>
                        }
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        function doSearch(page) {
            document.querySelector("input[name='page']").value = page;
            document.getElementById("frmSearch").submit();
        }
    </script>
}

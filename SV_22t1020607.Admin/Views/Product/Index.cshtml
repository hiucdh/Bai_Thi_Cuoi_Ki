@model SV_22T1020607.Models.Catalog.ProductSearchInput
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Product/Search" method="get" data-target="searchResult">
            <input type="hidden" name="@nameof(Model.PageSize)" value="@Model.PageSize" />
            <div class="row mb-3">
                <div class="col-sm-3">
                    <select class="form-select" name="@nameof(Model.CategoryID)">
                        <option value="0">-- Chọn loại hàng --</option>
                        @foreach (var item in SV22T1020607.BusinessLayers.CommonDataService.ListOfCategories())
                        {
                            if (item.CategoryID == Model.CategoryID)
                            {
                                <option value="@item.CategoryID" selected>@item.CategoryName</option>
                            }
                            else
                            {
                                <option value="@item.CategoryID">@item.CategoryName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-sm-3">
                    <select class="form-select" name="@nameof(Model.SupplierID)">
                        <option value="0">-- Chọn nhà cung cấp --</option>
                        @foreach (var item in SV22T1020607.BusinessLayers.PartnerDataService.ListOfSuppliers())
                        {
                            if (item.SupplierID == Model.SupplierID)
                            {
                                <option value="@item.SupplierID" selected>@item.SupplierName</option>
                            }
                            else
                            {
                                <option value="@item.SupplierID">@item.SupplierName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-sm-2">
                    <input type="number" name="@nameof(Model.MinPrice)" value="@Model.MinPrice" class="form-control" placeholder="Giá từ..." />
                </div>
                <div class="col-sm-2">
                    <input type="number" name="@nameof(Model.MaxPrice)" value="@Model.MaxPrice" class="form-control" placeholder="đến..." />
                </div>
                <div class="col-sm-2 text-end">
                    <a href="~/Product/Create" class="btn btn-primary d-flex align-items-center w-100 justify-content-center">
                        <i class="bi bi-plus-circle me-1"></i> Bổ sung
                    </a>
                </div>
            </div>

            <div class="input-group">
                <input type="text"
                       name="@nameof(Model.SearchValue)"
                       class="form-control"
                       value="@Model.SearchValue"
                       placeholder="Nhập tên mặt hàng cần tìm..." autofocus />
                <button class="btn btn-info d-flex align-items-center" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
    <!-- Nơi hiển thị kết quả tìm kiếm thông qua Ajax -->
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("formSearch");
            
            // Tải giữ liệu lần đầu
            paginationSearch(null, form, @Model.Page);

            // Gắn sự kiện submit cho form
            form.addEventListener("submit", function (e) {
                paginationSearch(e, this, 1);
            });
        });

        // Hàm doSearch dùng cho _Pager.cshtml
        function doSearch(page) {
            const form = document.getElementById("formSearch");
            paginationSearch(null, form, page);
        }
    </script>
}

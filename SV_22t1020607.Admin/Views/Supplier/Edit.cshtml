@model Supplier
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i>
                    Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Supplier/Save" method="post">
                    <input type="hidden" name="@nameof(Model.SupplierID)" value="@Model.SupplierID" />

                    <div class="mb-3">
                        <label class="form-label">Tên nhà cung cấp</label>
                        <input type="text"
                               name="@nameof(Model.SupplierName)"
                               value="@Model.SupplierName"
                               class="form-control"
                               placeholder="Nhập tên nhà cung cấp" autofocus />
                        @Html.ValidationMessage(nameof(Model.SupplierName), new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên giao dịch</label>
                        <input type="text"
                               name="@nameof(Model.ContactName)"
                               value="@Model.ContactName"
                               class="form-control"
                               placeholder="Nhập tên giao dịch" />
                        @Html.ValidationMessage(nameof(Model.ContactName), new { @class = "text-danger" })
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input type="tel"
                                   name="@nameof(Model.Phone)"
                                   value="@Model.Phone"
                                   class="form-control"
                                   placeholder="Nhập số điện thoại" />
                            @Html.ValidationMessage(nameof(Model.Phone), new { @class = "text-danger" })
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email"
                                   name="@nameof(Model.Email)"
                                   value="@Model.Email"
                                   class="form-control"
                                   placeholder="Nhập email" />
                            @Html.ValidationMessage(nameof(Model.Email), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea class="form-control"
                                  name="@nameof(Model.Address)"
                                  rows="3"
                                  placeholder="Nhập địa chỉ">@Model.Address</textarea>
                        @Html.ValidationMessage(nameof(Model.Address), new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select class="form-select" name="@nameof(Model.Province)">
                            <option value="">-- Chọn tỉnh / thành --</option>
                            @foreach (var p in DictionaryDataService.ListOfProvinces())
                            {
                                if (p.ProvinceName == Model.Province)
                                {
                                    <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                }
                                else
                                {
                                    <option value="@p.ProvinceName">@p.ProvinceName</option>
                                }
                            }
                        </select>
                        @Html.ValidationMessage(nameof(Model.Province), new { @class = "text-danger" })
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

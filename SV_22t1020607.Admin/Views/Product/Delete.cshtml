@model SV_22T1020607.Models.Catalog.Product
@{
    ViewBag.Title = "Xóa Mặt hàng";
    bool inUsed = ViewBag.InUsed ?? false;
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card @(inUsed ? "card-warning" : "card-danger") card-outline mt-5">
            <div class="card-header">
                <h5 class="card-title mb-0 @(inUsed ? "text-warning" : "text-danger")">
                    <i class="bi @(inUsed ? "bi-exclamation-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                    @(inUsed ? "Không thể xóa mặt hàng" : "Xác nhận xóa mặt hàng")
                </h5>
            </div>
            <div class="card-body text-center py-4">

                @* Ảnh sản phẩm *@
                <img src="@(string.IsNullOrEmpty(Model.Photo) ? "/images/products/nophoto.png" : $"/images/products/{Model.Photo}")"
                     onerror="this.src='/images/products/nophoto.png'"
                     class="img-thumbnail mb-3"
                     style="max-height: 120px; max-width: 120px; object-fit: contain;" />

                <div class="mb-3">
                    <div class="text-muted small">Mặt hàng:</div>
                    <strong class="fs-5">@Model.ProductName</strong>
                </div>

                @if (inUsed)
                {
                    @* Cảnh báo không thể xóa *@
                    <div class="alert alert-warning d-flex align-items-center gap-2 text-start" role="alert">
                        <i class="bi bi-shield-exclamation fs-5"></i>
                        <div>
                            Mặt hàng <strong>@Model.ProductName</strong> đã có trong đơn hàng, <strong>không thể xóa</strong>.
                            <br />
                            <small class="text-muted">Bạn có thể tắt trạng thái "Hiện đang được bán" thay thế.</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-center mt-3">
                        <a href="~/Product/Edit/@Model.ProductID" class="btn btn-primary px-4">
                            <i class="bi bi-pencil"></i> Chỉnh sửa
                        </a>
                        <a href="~/Product" class="btn btn-secondary px-4">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                    </div>
                }
                else
                {
                    @* Xác nhận xóa *@
                    <p class="text-muted mb-4">
                        Bạn có chắc chắn muốn xóa mặt hàng này không?
                        <br />
                        <small>Toàn bộ ảnh và thuộc tính liên quan cũng sẽ bị xóa.</small>
                    </p>
                    <form action="~/Product/Delete/@Model.ProductID" method="post">
                        <div class="d-flex gap-2 justify-content-center">
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash"></i> Đồng ý xóa
                            </button>
                            <a href="~/Product" class="btn btn-secondary px-4">
                                <i class="bi bi-x-circle"></i> Hủy bỏ
                            </a>
                        </div>
                    </form>
                }
            </div>
            <div class="card-footer text-muted small text-center">
                @if (inUsed)
                {
                    <span>Mã sản phẩm: #@Model.ProductID</span>
                }
                else
                {
                    <span>⚠️ Hành động này không thể hoàn tác.</span>
                }
            </div>
        </div>
    </div>
</div>

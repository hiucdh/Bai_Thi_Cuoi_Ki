@{
    ViewBag.Title = "Thay đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-12">
        <form method="post" asp-action="ChangePassword">

            @* Thông báo thành công *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Lỗi chung *@
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @ViewData.ModelState["Error"]!.Errors[0].ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card card-warning card-outline">
                <div class="card-body">
                    @* Mật khẩu cũ *@
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu cũ</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            <input type="password" name="oldPassword" class="form-control @(ViewData.ModelState["oldPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   placeholder="Nhập mật khẩu cũ" autofocus>
                        </div>
                        @if (ViewData.ModelState["oldPassword"]?.Errors.Count > 0)
                        {
                            <div class="text-danger mt-1">
                                <i class="bi bi-exclamation-circle"></i>
                                @ViewData.ModelState["oldPassword"]!.Errors[0].ErrorMessage
                            </div>
                        }
                    </div>

                    @* Mật khẩu mới *@
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-shield-lock-fill"></i>
                            </span>
                            <input type="password" name="newPassword" class="form-control @(ViewData.ModelState["newPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)">
                        </div>
                        @if (ViewData.ModelState["newPassword"]?.Errors.Count > 0)
                        {
                            <div class="text-danger mt-1">
                                <i class="bi bi-exclamation-circle"></i>
                                @ViewData.ModelState["newPassword"]!.Errors[0].ErrorMessage
                            </div>
                        }
                    </div>

                    @* Xác nhận mật khẩu mới *@
                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-check-circle-fill"></i>
                            </span>
                            <input type="password" name="confirmPassword" class="form-control @(ViewData.ModelState["confirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   placeholder="Nhập lại mật khẩu mới">
                        </div>
                        @if (ViewData.ModelState["confirmPassword"]?.Errors.Count > 0)
                        {
                            <div class="text-danger mt-1">
                                <i class="bi bi-exclamation-circle"></i>
                                @ViewData.ModelState["confirmPassword"]!.Errors[0].ErrorMessage
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer text-end">
                    <a href="~/" class="btn btn-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save"></i> Đổi mật khẩu
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

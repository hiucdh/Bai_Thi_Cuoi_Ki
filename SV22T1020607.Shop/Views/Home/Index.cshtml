@model IEnumerable<SV_22T1020607.Models.Catalog.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold text-primary">Sản Phẩm Nổi Bật</h1>
    <p class="text-muted fs-5">Hãy chọn cho mình những món hàng tuyệt vời nhất hôm nay.</p>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    @if(Model != null)
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 product-card">
                    <img src="http://localhost:5030/images/products/@(string.IsNullOrEmpty(item.Photo) ? "macbook.png" : item.Photo)" 
                         onerror="this.src='/images/no-image.png';" 
                         class="card-img-top p-3" alt="@item.ProductName" style="height: 200px; object-fit: contain;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate fw-bold" title="@item.ProductName">@item.ProductName</h5>
                        <p class="card-text text-danger fw-bold fs-5">@item.Price.ToString("N0") đ</p>
                        <div class="mt-auto">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductID" class="btn btn-outline-primary w-100 mb-2">Xem chi tiết</a>
                            <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.ProductID" class="btn btn-primary w-100"><i class="fa-solid fa-cart-plus me-1"></i> Mua ngay</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

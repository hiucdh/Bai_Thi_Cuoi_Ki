@model IEnumerable<SV22T1020607.Shop.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="fa-solid fa-cart-shopping me-2"></i>Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <h4 class="mb-3">Giỏ hàng đang trống</h4>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary"><i class="fa-solid fa-store me-1"></i> Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 100px">Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-center" style="width: 150px">Số lượng</th>
                        <th class="text-end">Thành tiền</th>
                        <th class="text-center" style="width: 100px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="http://localhost:5030/images/products/@(string.IsNullOrEmpty(item.Photo) ? "macbook.png" : item.Photo)" 
                                     onerror="this.src='/images/no-image.png';" 
                                     class="img-thumbnail" style="width: 80px; height: 80px; object-fit: contain;">
                            </td>
                            <td class="fw-bold">@item.ProductName</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-center">
                                <form asp-action="Update" method="post" class="d-flex justify-content-center">
                                    <input type="hidden" name="id" value="@item.ProductID" />
                                    <input type="number" class="form-control text-center form-control-sm me-2" name="quantity" value="@item.Quantity" min="1" style="width:70px">
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Cập nhật">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                </form>
                            </td>
                            <td class="text-end text-danger fw-bold">@item.TotalPrice.ToString("N0")</td>
                            <td class="text-center">
                                <a asp-action="Remove" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="return confirm('Xóa khỏi giỏ hàng?')">
                                    <i class="fa-solid fa-trash-can"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end fw-bold fs-5">Tổng cộng:</td>
                        <td class="text-end text-danger fw-bold fs-5">@Model.Sum(m => m.TotalPrice).ToString("N0") VNĐ</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <div>
                <a asp-action="Clear" class="btn btn-outline-danger" onclick="return confirm('Xóa sạch toàn bộ giỏ hàng?')">
                    <i class="fa-solid fa-broom me-1"></i> Xóa sạch giỏ hàng
                </a>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary ms-2">
                    <i class="fa-solid fa-arrow-left me-1"></i> Mua thêm
                </a>
            </div>
            @if(User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Order" asp-action="Init" class="btn btn-lg btn-primary fw-bold px-5">
                    Thanh Toán <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-lg btn-warning fw-bold px-5">
                    Đăng nhập để Thanh Toán
                </a>
            }
        </div>
    }
</div>

@model dynamic

@if (Model.PageCount > 1)
{
    <div class="card-footer">
        <ul class="pagination justify-content-center">
            @foreach (var pageItem in Model.GetDisplayPages())
            {
                if (pageItem.Page == 0)
                {
                    <li class="page-item disabled"><a class="page-link" href="#">...</a></li>
                }
                else if (pageItem.IsCurrent)
                {
                    <li class="page-item active"><a class="page-link" href="#">@pageItem.Page</a></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" href="javascript:;" onclick="doSearch(@pageItem.Page)">@pageItem.Page</a></li>
                }
            }
        </ul>
    </div>
}
